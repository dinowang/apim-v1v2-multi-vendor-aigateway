# @openAiEndpoint={{$dotenv FOUNDRY_OPENAI_URL}}
# @openAiKey={{$dotenv FOUNDRY_KEY}}
# @apimEndpoint={{$dotenv APIM_V1_OPENAI_URL}}
# @apimKey={{$dotenv APIM_V1_KEY}}
@apimEndpoint={{$dotenv APIM_V2_OPENAI_URL}}
@apimKey={{$dotenv APIM_V2_KEY}}


# @useBackend=openai-ai-endpoint
# @model=gpt-4o
# @useBackend=claude-ai-endpoint
# @model=claude-opus-4-6
@useBackend=gemini-ai-endpoint
@model=gemini-2.5-flash-lite

@csThreshold=7

###
POST {{apimEndpoint}}/deployments/{{model}}/chat/completions
    ?api-version=2025-01-01-preview
Content-Type: application/json
api-key: {{apimKey}}
X-UseBackend: {{useBackend}}
X-CS-Threshold: {{csThreshold}}

{"messages":[{"role":"system","content":"Hi! Write me a prose in 100 words."},{"role":"user","content":"How are you?"}],"max_tokens":50}

###
# @name geminiDirect
# Gemini API (OpenAI compatible) with static API key
# Get your API key from: https://aistudio.google.com/apikey
#
@geminiEndpoint={{$dotenv GEMINI_OPENAI_URL}}
@geminiApiKey={{$dotenv GEMINI_KEY}}
@geminiModel=gemini-2.5-flash-lite

POST {{geminiEndpoint}}/chat/completions
Content-Type: application/json
Authorization: Bearer {{geminiApiKey}}

{
  "model": "{{geminiModel}}",
  "messages": [
    {"role": "system", "content": "You are a helpful assistant"},
    {"role": "user", "content": "How are you?"}
  ],
  "max_tokens": 50
}